# Copy this file to `.env.local` (gitignored) and fill in real values.
#
# Variables prefixed with EXPO_PUBLIC_ are embedded in the client bundle at
# build time — they are not secret. Anything truly secret must never live in
# an EXPO_PUBLIC_ var.

# Supabase project URL, e.g. https://abcdxyz.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to ship in the client bundle.
# Available at: Dashboard → Project Settings → API → Project API keys → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only: set to "true" to bypass the auth-screen redirect in the
# root layout, so the app doesn't bounce unauthenticated users to
# /auth. Combine with the dev auto-login (default ON in __DEV__) for
# the fastest dev loop. MUST be unset (or anything other than "true")
# in any real build.
# EXPO_PUBLIC_SKIP_AUTH=true

# Dev-only escape hatch: set to "true" to OPT OUT of the dev
# auto-login (`dev@local.test`). When unset, the dev user is signed
# in automatically on every cold start in __DEV__ — flip this on
# when QA-ing the actual /auth screen. MUST be unset in any real
# build (production gates auto-login behind __DEV__ already).
# EXPO_PUBLIC_DISABLE_DEV_SIGNIN=true

# ─── Server-side scripts only (NEVER ship in client bundle) ──────────
# Required by `pnpm seed:dev` to bypass RLS and reset the dev user.
# Available at: Dashboard → Project Settings → API → service_role
# DO NOT prefix with EXPO_PUBLIC_ — that would embed it in the bundle.
# SUPABASE_SERVICE_ROLE_KEY=

# UUID of the dev user (dev@local.test) created manually in the
# Supabase dashboard. Used by the seed script as the target user_id.
# DEV_USER_ID=
