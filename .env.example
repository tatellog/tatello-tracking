# Copy this file to `.env.local` (gitignored) and fill in real values.
#
# Variables prefixed with EXPO_PUBLIC_ are embedded in the client bundle at
# build time — they are not secret. Anything truly secret must never live in
# an EXPO_PUBLIC_ var.

# Supabase project URL, e.g. https://abcdxyz.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to ship in the client bundle.
# Available at: Dashboard → Project Settings → API → Project API keys → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only: set to "true" to bypass the session guard in the root layout,
# so the app boots straight into (tabs) without a magic-link roundtrip.
# Useful while iterating on the UI against mock data. MUST be unset (or
# anything other than "true") in any real build.
# EXPO_PUBLIC_SKIP_AUTH=true
