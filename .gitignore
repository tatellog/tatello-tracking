# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# claude code — la config de equipo (CLAUDE.md, agents/, commands/) SÍ se
# versiona para que todo el equipo comparta los mismos agentes y reglas.
# Solo lo personal de cada máquina queda fuera.
.claude/settings.local.json

# JetBrains IDEs (user-local)
.idea/

# one-off local scripts (not for the repo)
scripts/reset-onboarding.ts

# generated native folders
/ios
/android

# Refactor safety net — visual-diff captures stay local
scripts/visual-diff/baseline/
scripts/visual-diff/current/
scripts/visual-diff/diff/
